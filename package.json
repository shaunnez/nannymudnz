{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.4.7",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:client": "vite",
    "dev:server": "node --watch --watch-path=packages/server/src --watch-path=packages/shared/src --import @swc-node/register/esm-register packages/server/src/index.ts",
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "kill": "bash scripts/kill-dev.sh",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p packages/shared/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.20",
    "@supabase/supabase-js": "^2.57.4",
    "colyseus": "^0.17.10",
    "colyseus.js": "^0.16.22",
    "lucide-react": "^0.344.0",
    "phaser": "^3.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@colyseus/sdk": "^0.17.41",
    "@colyseus/testing": "^0.17.11",
    "@eslint/js": "^9.9.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.30",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
